{
  "name": "@asaddu/uploadstuff",
  "version": "0.1.0",
  "author": "asaddu",
  "license": "MIT",
  "repository": "https://github.com/Asaddu/uploadstuff",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "homepage": "https://uploadstuff.dev",
  "module": "lib/index.ts",
  "types": "lib/index.ts",
  "type": "module",
  "files": [
    "lib",
    "esm",
    "cjs",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./lib/index.ts",
      "import": "./esm/index.js",
      "require": "./cjs/index.js"
    },
    "./react": {
      "types": "./lib/react.ts",
      "import": "./esm/react.js",
      "require": "./cjs/react.js"
    },
    "./react/styles.css": "./lib/styles.css"
  },
  "scripts": {
    "publish-docs": "npx vercel build --prod && npx vercel deploy --prebuilt --prod",
    "build-css": "tailwindcss -i ./styles.css -o ./lib/styles.css",
    "watch-css": "tailwindcss -i ./styles.css -o ./lib/styles.css --watch",
    "build": "pnpm run build-css && rimraf cjs esm && tsc --outDir esm -t esnext --noEmit false --allowImportingTsExtensions false --composite false --jsx react-jsx && tsc --outDir cjs -t es6 --sourceMap --noEmit false --allowImportingTsExtensions false --composite false -m commonjs --moduleResolution node --jsx react-jsx && echo '{\"type\": \"commonjs\"}' > cjs/package.json",
    "prepare": "pnpm run build"
  },
  "dependencies": {
    "rimraf": "^6.1.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dropzone": "^14.2.3 || ^15.0.0",
    "typescript": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/react": "^19.2.14",
    "react-dropzone": "^15.0.0",
    "typescript": "^5.9.3"
  },
  "browserslist": [
    "defaults"
  ]
}
